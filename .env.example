# App
NEXT_PUBLIC_APP_URL=http://localhost:3456
APP_ENV=development

# Supabase — required for auth (get from Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Drizzle / direct Postgres access (Project Settings > Database > Connection string)
# Use the Transaction-pooled URL (ends with :6543) for runtime; Session/Direct (:5432) for migrations.
DATABASE_URL=

# Server-only admin access (Project Settings > API > service_role)
SUPABASE_SERVICE_ROLE_KEY=

# Cookie signing (Phase 2 — leave blank in Phase 1)
COOKIE_SECRET=

# SanMar web services (PromoStandards) — request access from your SanMar rep.
# Server-only; never expose with NEXT_PUBLIC. SANMAR_ENV: edev (test) | production.
SANMAR_CUSTOMER_NUMBER=
SANMAR_USERNAME=
SANMAR_PASSWORD=
SANMAR_ENV=edev

# S&S Activewear REST API (https://api.ssactivewear.com) — self-service: generate
# an API key in your S&S account (Account > Account Settings > API). Auth is HTTP
# Basic = account number (username) + API key (password). Server-only.
SS_ACCOUNT_NUMBER=
SS_API_KEY=
